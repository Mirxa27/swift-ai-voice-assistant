# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/newomen?schema=public"
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
NEXT_PUBLIC_ADMIN_PASSWORD="secure-admin-password"

# Application URLs
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_SOCKET_URL="wss://your-socket-server.com"

# AI Provider API Keys
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="..."
DEEPGRAM_API_KEY="..."
ELEVENLABS_API_KEY="..."
HUMEAI_API_KEY="..."

# PayPal Configuration
PAYPAL_CLIENT_ID="..."
PAYPAL_CLIENT_SECRET="..."
PAYPAL_WEBHOOK_ID="..."
PAYPAL_GROWTH_PLAN_ID="..."
PAYPAL_TRANSFORMATION_PLAN_ID="..."
NODE_ENV="production"

# Email Service (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="noreply@newomen.ai"

# Analytics (Optional)
NEXT_PUBLIC_GA_ID="G-..."
NEXT_PUBLIC_MIXPANEL_TOKEN="..."

# Vercel Configuration
VERCEL_TOKEN="..."
VERCEL_PROJECT_ID="..."
VERCEL_TEAM_ID="..."

# Feature Flags
ENABLE_VOICE_MODE="true"
ENABLE_COMMUNITY="true"
ENABLE_WELLNESS="true"
ENABLE_GAMIFICATION="true"

# Rate Limiting
RATE_LIMIT_REQUESTS="100"
RATE_LIMIT_WINDOW="900000"

# Storage (Optional for future features)
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"
S3_BUCKET="newomen-assets"
