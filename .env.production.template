# ====================================
# PRODUCTION ENVIRONMENT VARIABLES
# ====================================
# Copy this file to .env.production and fill in your values
# Then add these to Vercel Dashboard → Settings → Environment Variables

# ====================================
# 🔴 REQUIRED - Database Configuration
# ====================================

# PostgreSQL Database URL
# Get free PostgreSQL from: https://supabase.com or https://neon.tech
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=

# Redis Cache URL  
# Get free Redis from: https://upstash.com
# Format: redis://default:password@endpoint.upstash.io:6379
REDIS_URL=

# ====================================
# 🔴 REQUIRED - Security & Authentication
# ====================================

# JWT Secret Key (minimum 32 characters)
# Generate one: openssl rand -base64 32
JWT_SECRET=

# Admin Panel Password
NEXT_PUBLIC_ADMIN_PASSWORD=

# ====================================
# 🔴 REQUIRED - Application Settings
# ====================================

# Your Vercel App URL (update after first deployment)
# Format: https://your-app-name.vercel.app
NEXT_PUBLIC_APP_URL=

# Socket.IO Server URL (optional, for real-time features)
NEXT_PUBLIC_SOCKET_URL=

# ====================================
# 🟡 REQUIRED - AI Providers (need at least ONE)
# ====================================

# OpenAI API Key (Recommended)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API Key (Alternative to OpenAI)
# Get from: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=

# ====================================
# 🟢 OPTIONAL - Additional AI Services
# ====================================

# Deepgram API Key (for speech-to-text)
# Get from: https://console.deepgram.com
# DEEPGRAM_API_KEY=

# ElevenLabs API Key (for text-to-speech)
# Get from: https://elevenlabs.io
# ELEVENLABS_API_KEY=

# ====================================
# 🟢 OPTIONAL - Payment Processing
# ====================================

# PayPal Integration
# Get from: https://developer.paypal.com
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=

# PayPal Subscription Plan IDs
# PAYPAL_GROWTH_PLAN_ID=
# PAYPAL_TRANSFORMATION_PLAN_ID=

# ====================================
# 🟢 OPTIONAL - Feature Flags
# ====================================

# Enable/disable features
ENABLE_VOICE_MODE=true
ENABLE_GAMIFICATION=true

# ====================================
# 🟢 OPTIONAL - Analytics & Monitoring
# ====================================

# Vercel Analytics (auto-configured)
# VERCEL_ANALYTICS_ID=

# ====================================
# DEPLOYMENT CHECKLIST
# ====================================
# 
# 1. ✅ Copy this file to .env.production
# 2. ✅ Fill in all REQUIRED variables
# 3. ✅ Add these to Vercel Dashboard
# 4. ✅ Deploy with: vercel --prod
# 5. ✅ Run migrations: npx prisma migrate deploy
# 
# ====================================